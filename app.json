{
  "expo": {
    "name": "easyfrotas",
    "slug": "easyfrotas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.NFC",
        "android.permission.NFC",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.NFC",
        "android.permission.NFC",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.easyfrotas"
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Permita o uso de NFC para identificar e vincular TAGs dos veículos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita acesso à galeria para enviar a foto do veículo."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita acesso a camera para leitura automatica da quilometragem."
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://SEU-PROJETO.supabase.co",
      "supabaseAnonKey": "SUA_CHAVE_ANON_PUBLICA"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
